{
  "name": "flat-white",
  "version": "0.3.0",
  "description": "Australian addresses. Flattened and served.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "generate:sql": "node --experimental-strip-types scripts/generate-main-sql.ts",
    "build": "npm run generate:sql && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fixture": "./scripts/build-fixture-only.sh",
    "prepare": "husky || true"
  },
  "homepage": "https://github.com/jbejenar/flat-white",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbejenar/flat-white.git"
  },
  "author": "jbejenar",
  "bugs": {
    "url": "https://github.com/jbejenar/flat-white/issues"
  },
  "keywords": [
    "australia",
    "gnaf",
    "addresses",
    "ndjson",
    "boundaries",
    "geocoding",
    "data-transformation",
    "open-data"
  ],
  "dependencies": {
    "@dsnp/parquetjs": "^1.8.7",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "license": "Apache-2.0",
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
