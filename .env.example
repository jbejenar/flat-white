# flat-white environment variables

# PostgreSQL (ephemeral — used during build only)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gnaf

# G-NAF data paths
GNAF_DATA_PATH=./data/G-NAF
ADMIN_BDYS_PATH=./data/Administrative-Boundaries

# Build configuration
GNAF_VERSION=2026.02
STATES=VIC
OUTPUT_DIR=./output
