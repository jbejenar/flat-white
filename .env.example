# flat-white environment variables
# These map to CLI flags when running via Docker:
#   docker run flat-white --states VIC --output /output/

# PostgreSQL (ephemeral — used during build only)
# Used by: docker-compose.yml, src/load.ts, src/flatten.ts
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gnaf

# G-NAF data paths (CLI: --gnaf-path, --admin-path)
# Downloaded by src/download.ts from data.gov.au (~6.5GB combined)
GNAF_DATA_PATH=./data/G-NAF
ADMIN_BDYS_PATH=./data/FEB26_AdminBounds_GDA_2020_SHP

# Build configuration
GNAF_VERSION=2026.02              # Quarterly release (CLI: input to workflow)
STATES=VIC                         # Comma-separated or ALL (CLI: --states)
OUTPUT_DIR=./output                # Where NDJSON files land (CLI: --output)
